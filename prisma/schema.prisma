datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  domain           String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  users            User[]
  workflows        Workflow[]
  contacts         Contact[]
  opportunities    Opportunity[]
  tasks            Task[]
  notes            Note[]
  auditLogs        AuditLog[]
  businessSettings BusinessSettings?

  @@index([deletedAt])
}

enum Role {
  SUPERADMIN
  ADMIN
  MEMBER
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  role          Role           @default(MEMBER)
  tenantId      String?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  refreshTokens RefreshToken[]
  assignedTasks Task[]         @relation("TaskAssignee")
  notes         Note[]
  auditLogs     AuditLog[]     @relation("UserAuditLogs")

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model BusinessSettings {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName    String?
  timezone       String   @default("UTC")
  webhookSecret  String?
  aiModelDefault String   @default("gemini-2.5-flash")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Fix #22: No deletedAt — BusinessSettings are an extension of Tenant, not independently deleted.

  @@index([tenantId])
}

model Contact {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String?
  email         String?
  phone         String?
  company       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  opportunities Opportunity[]
  tasks         Task[]
  notes         Note[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@index([email])
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

model Opportunity {
  id            String           @id @default(uuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title         String
  // Fix #11: Decimal prevents IEEE 754 floating-point rounding errors for currency storage.
  value         Decimal          @default(0.00) @db.Decimal(10, 2)
  probability   Int              @default(0) // 0-100 percentage
  stage         OpportunityStage @default(LEAD)
  expectedClose DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  tasks         Task[]
  notes         Note[]

  @@index([tenantId])
  @@index([contactId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  status        TaskStatus   @default(TODO)
  dueDate       DateTime?
  
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([assigneeId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([tenantId, deletedAt])
}

model Note {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  content       String       @db.Text
  
  authorId      String?
  author        User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, contactId, createdAt])
  @@index([tenantId, opportunityId, createdAt])
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  action        String
  entityType    String   // e.g., 'Contact', 'Opportunity'
  entityId      String
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  // Fix #14: Time-ordered audit queries need this index.
  @@index([tenantId, createdAt])
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenVersion Int       @default(0) // For RTR (Refresh Token Rotation) revocation
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([userId])
  // Fix #15: RTR queries filter by userId AND deletedAt — composite index is required.
  @@index([userId, deletedAt])
}

model Workflow {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  definition  Json     // DAG structure
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  executions  WorkflowExecution[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model WorkflowExecution {
  id          String          @id @default(uuid())
  // Fix #13: tenantId added for direct tenant-scoped queries without requiring a Workflow join.
  tenantId    String
  workflowId  String
  workflow    Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      ExecutionStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([workflowId])
  @@index([tenantId, status])
}
